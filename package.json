{
  "packageManager": "pnpm@11.9.0",
  "name": "tw-minesweeper-client",
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm run lint:prettier && pnpm run lint:stylelint && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:prettier:fix && pnpm run lint:stylelint:fix && pnpm run lint:eslint:fix",
    "lint:prettier": "prettier --check src",
    "lint:prettier:fix": "prettier --write src",
    "lint:stylelint": "stylelint 'src/**/*.css'",
    "lint:stylelint:fix": "stylelint --fix 'src/**/*.css'",
    "lint:eslint": "eslint src",
    "lint:eslint:fix": "eslint --fix src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
